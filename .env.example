# Copiar este archivo a .env (no subir el .env real a GitHub)

# Conexión a MongoDB LOCAL (instalado en tu máquina, versión 8.3.4).
# No necesita usuario/contraseña porque corre en localhost sin autenticación
# habilitada por defecto. Si configuraste usuario/clave, usa:
# mongodb://usuario:[email protected]:27017/
MONGO_URI=mongodb://localhost:27017/
